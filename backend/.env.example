# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:8080

# JWT Secret (generate a secure random string)
JWT_SECRET=your-secret-key-here

# Google OAuth Configuration
# To get these credentials:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select an existing one
# 3. Go to "APIs & Services" > "Credentials"
# 4. Click "Create Credentials" > "OAuth client ID"
# 5. Select "Web application" as the application type
# 6. Add authorized JavaScript origins: http://localhost:8080 (and your production URL)
# 7. Add authorized redirect URIs: http://localhost:8080/auth (and your production URL)
# 8. Copy the Client ID and Client Secret below
# Replace with your actual Google OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
